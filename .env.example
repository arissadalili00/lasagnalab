# EmailJS — sends receipts FROM thecreamypastaco@gmail.com TO customer login email
# Setup: https://www.emailjs.com (free)
#
# LOCAL DEV (optional — overrides src/data/site.ts defaults):
# 1. Copy this file to .env and fill in the 3 values
# 2. Restart: npm run dev
#
# NETLIFY / LIVE:
# EmailJS keys are already in src/data/site.ts (public client keys).
# After changing them, push to GitHub — Netlify will rebuild automatically.
# In EmailJS dashboard, allow your live domain (e.g. creamypastaco.netlify.app).
#
# NEVER put your Gmail password here — EmailJS uses Google sign-in instead.

VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=
