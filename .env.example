# EmailJS — sends receipts FROM thecreamypastaco@gmail.com TO customer login email
# Setup: https://www.emailjs.com (free)
#
# 1. Sign up → Email Services → Add Gmail → sign in as thecreamypastaco@gmail.com
# 2. Email Templates → create template (see comments in src/utils/email.ts)
# 3. Account → Public Key → copy keys below
# 4. Copy this file to .env and fill in the 3 values
# 5. Restart: npm run dev
#
# NEVER put your Gmail password here — EmailJS uses Google sign-in instead.

VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=
